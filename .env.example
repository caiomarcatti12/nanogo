APP_NAME=Application
VERSION=1.0.0 
ENV=dev # production|dev

SERVER_PORT=8080
SERVER_CERTIFICATE=./server/server.crt #Opcional
SERVER_KEY=./server/server.key #Opcional

REDIS_ADDR=host.docker.internal
REDIS_NAMESPACE=namespace
REDIS_PASSWORD=

MONGO_URI=mongodb+srv://usr_nanogo:nanogo@host.docker.internal/nanogo
MONGO_DBNAME=nanogo

RABBITMQ_HOST=host.docker.internal
RABBITMQ_USER=nanogo
RABBITMQ_PASSWORD=nanogo
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

JTW_SECRET=my-pass

ENABLE_PROMETHEUS=false
PROMETHEUS_PREFIX=
PROMETHEUS_ROUTE=/metrics
PROMETHEUS_TOKEN=false
